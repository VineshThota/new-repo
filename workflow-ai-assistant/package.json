{
  "name": "workflow-ai-assistant",
  "version": "1.0.0",
  "description": "AI-powered workflow automation assistant that combines LinkedIn trends with real-world automation challenges",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "ai",
    "automation",
    "workflow",
    "linkedin",
    "trends",
    "integration",
    "openai",
    "express",
    "api"
